{
  "name": "@url-shortener/infrastructure",
  "version": "0.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .turbo",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@url-shortener/engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.22.0",
    "typescript": "^5.9.3"
  }
}
